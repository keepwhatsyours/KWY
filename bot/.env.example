# --- REQUIRED ---

# Bot token from https://discord.com/developers/applications
# (your-app → Bot → Reset Token)
DISCORD_TOKEN=paste-your-bot-token-here

# Channel ID of the channel you want mirrored.
# In Discord: Settings → Advanced → Developer Mode = ON,
# then right-click the channel → Copy Channel ID
CHANNEL_ID=000000000000000000

# --- OPTIONAL ---

# Server (guild) ID — only used for log messages.
GUILD_ID=000000000000000000

# How many recent messages to keep in /feed (max 200)
MAX_MESSAGES=50

# HTTP port the /feed endpoint listens on
PORT=3030

# CORS origin(s). Use * while testing, then lock down to your site, e.g.:
# ALLOWED_ORIGIN=https://keepwhatsyours.ai
ALLOWED_ORIGIN=*

# GMGN API key — required for /gmgn endpoint (live token data proxy)
# Get yours at https://gmgn.ai/ai
GMGN_API_KEY=
